<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <ExcludeByFile>
            **/Program.cs,
            **/Common/*.cs,
            **/TenantManagement/*.cs,
            **/Rbac/*.cs,
            **/Audit/*.cs,
            **/Security/*.cs,
            **/Storage/*.cs,
            **/DependencyInjection.cs,
            **/Shared/*.cs,
            **/FoundationAbstractions.cs
          </ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
