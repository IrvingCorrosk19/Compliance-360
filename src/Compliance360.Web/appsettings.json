{
  "ConnectionStrings": {
    "Compliance360": ""
  },
  "Jwt": {
    "Issuer": "Compliance360",
    "Audience": "Compliance360.Web",
    "SigningKey": "",
    "AccessTokenMinutes": 15
  },
  "RefreshTokens": {
    "LifetimeDays": 30
  },
  "PasswordPolicy": {
    "MinimumLength": 12,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSymbol": true,
    "PasswordHistoryLimit": 5
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "Audit": {
    "DefaultRetentionDays": 2555,
    "MaxPageSize": 200,
    "ReadPermission": "AUDIT.READ"
  },
  "Storage": {
    "Provider": "Local",
    "ContainerName": "compliance360-documents",
    "RootPath": "storage"
  },
  "Notifications": {
    "DefaultProvider": "Smtp",
    "FailoverProvider": "SendGrid",
    "MaxRetryCount": 3,
    "RetryBaseDelaySeconds": 60,
    "Providers": {
      "Smtp": {
        "Host": "",
        "Port": 587,
        "Username": "",
        "Secret": "",
        "FromAddress": "",
        "FromName": "Compliance 360",
        "UseSsl": true
      },
      "SendGrid": {
        "BaseUrl": "https://api.sendgrid.com",
        "Secret": "",
        "FromAddress": "",
        "FromName": "Compliance 360"
      },
      "Mailgun": {
        "BaseUrl": "https://api.mailgun.net",
        "Domain": "",
        "Secret": "",
        "FromAddress": "",
        "FromName": "Compliance 360"
      },
      "Resend": {
        "BaseUrl": "https://api.resend.com",
        "Secret": "",
        "FromAddress": "",
        "FromName": "Compliance 360"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Observability": {
    "ServiceName": "Compliance360.Enterprise",
    "Environment": "Production",
    "HighLatencyThresholdMs": 1000,
    "HighErrorRatePercent": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
