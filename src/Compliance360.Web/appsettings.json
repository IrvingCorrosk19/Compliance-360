{
  "ConnectionStrings": {
    "Compliance360": ""
  },
  "Jwt": {
    "Issuer": "Compliance360",
    "Audience": "Compliance360.Web",
    "SigningKey": "",
    "AccessTokenMinutes": 15
  },
  "RefreshTokens": {
    "LifetimeDays": 30
  },
  "PasswordPolicy": {
    "MinimumLength": 12,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSymbol": true,
    "PasswordHistoryLimit": 5
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "Audit": {
    "DefaultRetentionDays": 2555,
    "MaxPageSize": 200,
    "ReadPermission": "AUDIT.READ"
  },
  "Storage": {
    "Provider": "Local",
    "ContainerName": "compliance360-documents",
    "RootPath": "storage"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
