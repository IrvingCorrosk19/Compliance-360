{
  "ConnectionStrings": {
    "Compliance360": ""
  },
  "Jwt": {
    "Issuer": "Compliance360",
    "Audience": "Compliance360.Web",
    "SigningKey": "",
    "AccessTokenMinutes": 15
  },
  "RefreshTokens": {
    "LifetimeDays": 30
  },
  "Storage": {
    "Provider": "Local",
    "ContainerName": "compliance360-documents",
    "RootPath": "storage"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
